{
  "name": "day-trading-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently --kill-others-on-fail \"next dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron:build": "next build && cp -r .next/static .next/standalone/.next/ && (cp -r public .next/standalone/ 2>/dev/null || true) && electron-builder",
    "electron:build:mac": "next build && cp -r .next/static .next/standalone/.next/ && (cp -r public .next/standalone/ 2>/dev/null || true) && electron-builder --mac",
    "electron:build:win": "next build && cp -r .next/static .next/standalone/.next/ && (cp -r public .next/standalone/ 2>/dev/null || true) && electron-builder --win",
    "electron:build:linux": "next build && cp -r .next/static .next/standalone/.next/ && (cp -r public .next/standalone/ 2>/dev/null || true) && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lightweight-charts": "^4.2.2",
    "lucide-react": "^0.469.0",
    "next": "14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.quantdash.app",
    "productName": "QuantDash",
    "asar": false,
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "package.json",
      "!**/.env",
      "!**/.env.local",
      "!**/.env.*.local"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
